<script>
var rows = Array.from(document.querySelectorAll('#tbody tr'))
var sortCol = 1, sortDir = -1

function numVal(tr) {
  return parseInt(tr.querySelectorAll('td')[1].querySelector('a').textContent)
}
function cellText(tr, col) {
  return tr.querySelectorAll('td')[col].textContent.toLowerCase()
}

function render() {
  var q = document.getElementById('q').value.toLowerCase()
  var yr = document.getElementById('yr').value
  var visible = rows.filter(function(tr) {
    var tds = tr.querySelectorAll('td')
    var matchY = !yr || tds[4].textContent === yr
    var matchQ = !q || tds[2].textContent.toLowerCase().includes(q) || tds[5].textContent.toLowerCase().includes(q)
    return matchY && matchQ
  })
  visible.sort(function(a, b) {
    if (sortCol === 1) return sortDir * (numVal(a) - numVal(b))
    return sortDir * cellText(a, sortCol).localeCompare(cellText(b, sortCol))
  })
  var tbody = document.getElementById('tbody')
  tbody.innerHTML = ''
  visible.forEach(function(tr) { tbody.appendChild(tr) })
  document.getElementById('count').textContent = visible.length + ' entries'
}

document.getElementById('q').addEventListener('input', render)
document.getElementById('yr').addEventListener('change', render)

document.querySelectorAll('th[data-col]').forEach(function(th) {
  th.addEventListener('click', function() {
    var col = parseInt(th.dataset.col)
    if (sortCol === col) { sortDir *= -1 } else { sortCol = col; sortDir = col === 1 ? -1 : 1 }
    document.querySelectorAll('th[data-col]').forEach(function(t) { t.classList.remove('sorted-asc','sorted-desc') })
    th.classList.add(sortDir === 1 ? 'sorted-asc' : 'sorted-desc')
    render()
  })
})

render()
</script>
